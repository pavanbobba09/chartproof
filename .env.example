# Backend / pipeline
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CHROMA_DIR=.chroma
ALLOWED_ORIGINS=http://localhost:3000

# Frontend (set in frontend env or Vercel)
